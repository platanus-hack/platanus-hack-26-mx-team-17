# Vision API — variables de entorno (ejemplo). Copiar a .env y ajustar.
# NO poner secretos reales aquí. Este archivo SÍ se versiona.

# Modelo de visión (congelado por contrato).
VISION_MODEL_NAME=facebook/dinov2-small

# Dispositivo de inferencia: auto | cpu | cuda
#   auto -> CUDA si está disponible (local), si no CPU (Railway).
VISION_DEVICE=auto

# Calentar el modelo al arrancar para mitigar cold start.
VISION_WARMUP_ON_STARTUP=true

# --- Pendiente (tareas posteriores, lado servidor; NO en el cliente) ---
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=
