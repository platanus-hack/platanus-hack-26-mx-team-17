# Variables de entorno — Huella SOS (mobile).
# Sólo NOMBRES y marcadores. NO poner valores reales aquí ni versionar secretos.
# Copia a `.env` (ignorado por git) y rellena con tus credenciales.

# --- Públicas: se exponen al cliente (EXPO_PUBLIC_*) ---
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=   # token PÚBLICO de Mapbox (pk....)
EXPO_PUBLIC_VISION_API_URL=

# --- Secretas: SÓLO en build (EAS secret / .env local). NUNCA al cliente ni a git ---
RNMAPBOX_MAPS_DOWNLOAD_TOKEN=      # token SECRETO de descarga de Mapbox (sk....)
